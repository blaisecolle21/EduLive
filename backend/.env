JWT_SECRET=secret_key
# ========================================
# CONFIGURATION EMAIL
# ========================================

#  MAILDEV (Pour développement local)
# Activer cette configuration pour utiliser Maildev
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false

#  URL du frontend (pour les liens dans les emails)
# FRONTEND_URL=http://localhost:5173

# ========================================
# GMAIL (Pour production - À DÉCOMMENTER)
# ========================================
# Pour utiliser Gmail en production :
# 1. Aller sur https://myaccount.google.com/security
# 2. Activer "Validation en deux étapes"
# 3. Générer un "Mot de passe d'application"
# 4. Utiliser ce mot de passe dans SMTP_PASS

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=votre.email@gmail.com
# SMTP_PASS=votre_mot_de_passe_application
# SMTP_SECURE=false

# ========================================
# AUTRES FOURNISSEURS EMAIL (Pour production)
# ========================================

# --- OUTLOOK / HOTMAIL ---
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_USER=votre.email@outlook.com
# SMTP_PASS=votre_mot_de_passe
# SMTP_SECURE=false

